# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eazy_italian
REDIS_URL=redis://localhost:6379

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=True
SMTP_SSL=False

# File Storage (MinIO/S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=eazy-italian
MINIO_SECURE=False

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Configuration
DEBUG=True
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME=Eazy Italian

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Eazy Italian
# Frontend Stripe publishable key (pk_test_... in dev, pk_live_... in production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Backend Stripe secret key (sk_test_... in dev, sk_live_... in production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# AI Provider Configuration
# Options: "groq" or "ollama" (default: "ollama" for backward compatibility)
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=60

# Ollama Configuration (if using AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Hugging Face Configuration (for image generation)
# 1. Free account at huggingface.co → Settings → Access Tokens → New (read)
HF_API_KEY=your-huggingface-api-key-here
# 2. Optionally override the model (default: Lykon/dreamshaper-8)
HF_MODEL=stabilityai/stable-diffusion-2-1

# Support chat Telegram integration
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-numeric-user-id
SUPPORT_REPLY_SECRET=your-random-secret